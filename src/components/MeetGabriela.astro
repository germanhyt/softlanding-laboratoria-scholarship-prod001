---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="historias" class="bg-brand-gray py-24 px-6 scroll-mt-24">
  <div
    class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-start"
  >
    <img
      src="/images/photo-gabriela.jpg"
      alt={t("img.gabriela.alt")}
      class="w-full rounded-2xl object-cover aspect-[4/5]"
      data-reveal="left"
      loading="lazy"
    />
    <div data-reveal="right" style="--reveal-delay: 120ms">
      <div
        class="text-xs font-semibold tracking-[0.2em] uppercase text-brand-magenta"
      >
        {t("gabriela.label")}
      </div>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold">{t("gabriela.title")}</h2>
      <div class="mt-6 space-y-4 text-lg leading-relaxed">
        <p>{t("gabriela.p1")}</p>
        <p>{t("gabriela.p2")}</p>
        <p>{t("gabriela.p3")}</p>
        <p>{t("gabriela.p4")}</p>
      </div>
      <div class="mt-8">
        <blockquote class="border-l-4 border-brand-magenta pl-5 py-2 text-left">
          <p class="text-lg md:text-xl italic leading-relaxed">
            {t("gabriela.quote")}
          </p>
          <footer class="mt-3 text-sm opacity-80 not-italic">
            {t("gabriela.attribution")}
          </footer>
        </blockquote>
      </div>
    </div>
  </div>
</section>