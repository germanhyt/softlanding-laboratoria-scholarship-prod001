---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Problem from "../components/Problem.astro";
import Building from "../components/Building.astro";
import GiftTiers from "../components/GiftTiers.astro";
import ImpactWays from "../components/ImpactWays.astro";
import CohortUpdates from "../components/CohortUpdates.astro";
import MeetGabriela from "../components/MeetGabriela.astro";
import FaqAccordion from "../components/FaqAccordion.tsx";
import FinalCta from "../components/FinalCta.astro";
import SiteFooter from "../components/SiteFooter.astro";
import RevealInit from "../components/RevealInit.astro";
import { getFaqItems } from "../data/faq";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const faqItems = getFaqItems(lang);
---

<Layout
  lang={lang}
  title={t("meta.title")}
  description={t("meta.description")}
  faqItems={faqItems}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Problem lang={lang} />
    <Building lang={lang} />
    <GiftTiers lang={lang} />
    <ImpactWays lang={lang} />
    <CohortUpdates lang={lang} />
    <MeetGabriela lang={lang} />
    <FaqAccordion client:load items={faqItems} title={t("faq.title")} />
    <FinalCta lang={lang} />
  </main>
  <SiteFooter lang={lang} />
  <RevealInit />
</Layout>