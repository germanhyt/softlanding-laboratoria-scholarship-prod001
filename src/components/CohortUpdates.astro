---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="bg-white py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center" data-reveal>
      <div
        class="text-xs font-semibold tracking-[0.2em] uppercase text-brand-magenta"
      >
        {t("cohort.label")}
      </div>
      <h2 class="mt-3 text-3xl md:text-5xl font-bold">{t("cohort.title")}</h2>
    </div>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-5">
      <div
        class="rounded-2xl border border-black/10 p-6"
        data-reveal
        style="--reveal-delay: 60ms"
      >
        <div class="text-3xl">📚</div>
        <p class="mt-3 leading-relaxed">{t("cohort.update1")}</p>
      </div>
      <div
        class="rounded-2xl border border-black/10 p-6"
        data-reveal
        style="--reveal-delay: 140ms"
      >
        <div class="text-3xl">💼</div>
        <p class="mt-3 leading-relaxed">{t("cohort.update2")}</p>
      </div>
      <div
        class="rounded-2xl border border-black/10 p-6"
        data-reveal
        style="--reveal-delay: 220ms"
      >
        <div class="text-3xl">🤝</div>
        <p class="mt-3 leading-relaxed">{t("cohort.update3")}</p>
      </div>
    </div>
    <p
      class="mt-6 text-center italic text-sm text-brand-ink/60"
      data-reveal
      style="--reveal-delay: 280ms"
    >
      {t("cohort.footer")}
    </p>
  </div>
</section>