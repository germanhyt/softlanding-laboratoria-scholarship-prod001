---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<footer class="bg-white py-14 px-6 border-t border-black/10">
  <div
    class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6"
  >
    <div>
      <img
        src="/images/logo-laboratoria-black.png"
        alt={t("logo.alt")}
        class="h-7 w-auto md:h-8"
        width="1223"
        height="148"
      />
      <p class="text-sm text-brand-ink/70 mt-2">{t("footer.tagline")}</p>
    </div>
    <nav class="text-sm">
      <a href="https://laboratoria.la/" class="hover:text-brand-magenta"
        >{t("footer.knowUs")}</a
      >
    </nav>
  </div>
</footer>
