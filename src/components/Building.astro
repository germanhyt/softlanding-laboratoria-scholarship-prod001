---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="impacto" class="bg-white py-24 px-6 scroll-mt-24">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
    <div data-reveal="left">
      <h2 class="text-3xl md:text-5xl font-bold leading-tight">
        {t("building.title")}
      </h2>
      <p class="mt-6 text-lg leading-relaxed">
        {t("building.body")}
      </p>
      <p class="mt-4 text-lg leading-relaxed">
        {t("building.support")}
      </p>
    </div>
    <img
      src="/images/photo-community.jpg"
      alt=""
      class="w-full rounded-2xl object-cover aspect-[4/5]"
      data-reveal="right"
      style="--reveal-delay: 140ms"
    />
  </div>
  <div
    class="max-w-6xl mx-auto mt-20 grid grid-cols-1 md:grid-cols-3 gap-10 text-center"
  >
    <div data-reveal style="--reveal-delay: 0ms">
      <div class="text-5xl md:text-6xl font-bold text-brand-magenta">
        {t("building.metric1.value")}
      </div>
      <div class="mt-2 text-base font-medium">{t("building.metric1.label")}</div>
    </div>
    <div data-reveal style="--reveal-delay: 120ms">
      <div class="text-5xl md:text-6xl font-bold text-brand-magenta">
        {t("building.metric2.value")}
      </div>
      <div class="mt-2 text-base font-medium">{t("building.metric2.label")}</div>
    </div>
    <div data-reveal style="--reveal-delay: 240ms">
      <div class="text-5xl md:text-6xl font-bold text-brand-magenta">
        {t("building.metric3.value")}
      </div>
      <div class="mt-2 text-base font-medium">{t("building.metric3.label")}</div>
    </div>
  </div>
</section>