---
import ImpactStats from "./ImpactStats.tsx";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const metrics = [
  {
    end: Number(t("building.metric1.end")),
    prefix: t("building.metric1.prefix") || undefined,
    suffix: t("building.metric1.suffix") || undefined,
    label: t("building.metric1.label"),
  },
  {
    end: Number(t("building.metric2.end")),
    prefix: t("building.metric2.prefix") || undefined,
    suffix: t("building.metric2.suffix") || undefined,
    label: t("building.metric2.label"),
  },
  {
    end: Number(t("building.metric3.end")),
    prefix: t("building.metric3.prefix") || undefined,
    suffix: t("building.metric3.suffix") || undefined,
    label: t("building.metric3.label"),
  },
];
---

<section id="impacto" class="bg-white py-24 px-6 scroll-mt-24">
  <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
    <div data-reveal="left">
      <h2 class="text-3xl md:text-5xl font-bold leading-tight">
        {t("building.title")}
      </h2>
      <p class="mt-6 text-lg leading-relaxed">
        {t("building.body")}
      </p>
      <p class="mt-4 text-lg leading-relaxed">
        {t("building.support")}
      </p>
    </div>
    <img
      src="/images/photo-community.jpg"
      alt={t("img.community.alt")}
      class="w-full rounded-2xl object-cover aspect-[4/5]"
      data-reveal="right"
      style="--reveal-delay: 140ms"
      loading="lazy"
    />
  </div>
  <ImpactStats client:visible metrics={metrics} />
</section>