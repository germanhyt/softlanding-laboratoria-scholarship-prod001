---
import { DONATE_URL } from "../data/faq";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="relative min-h-[92vh] flex items-center justify-center text-white overflow-hidden"
>
  <img
    src="/images/photo-hero.jpg"
    alt=""
    class="hero-media absolute inset-0 h-full w-full object-cover"
    data-reveal="scale"
    style="--reveal-delay: 0ms"
  />
  <div class="absolute inset-0 bg-brand-ink/70"></div>
  <div class="relative z-10 max-w-3xl px-6 pb-24 pt-32 text-center md:pt-36">
    <h1
      class="text-5xl md:text-7xl font-bold tracking-tight leading-[1.05]"
      data-reveal
      style="--reveal-delay: 120ms"
    >
      {t("hero.title")}
    </h1>
    <p
      class="mt-6 text-lg md:text-xl leading-relaxed opacity-95"
      data-reveal
      style="--reveal-delay: 260ms"
    >
      {t("hero.body")}
    </p>
    <div
      class="mt-10 mx-auto max-w-2xl"
      data-reveal
      style="--reveal-delay: 400ms"
    >
      <blockquote class="border-l-4 border-brand-magenta pl-5 py-2 text-left">
        <p class="text-lg md:text-xl italic leading-relaxed">
          {t("hero.quote")}
        </p>
        <footer class="mt-3 text-sm opacity-80 not-italic">
          {t("hero.attribution")}
        </footer>
      </blockquote>
    </div>
    <div class="mt-10" data-reveal style="--reveal-delay: 540ms">
      <a
        href={DONATE_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta inline-flex items-center justify-center rounded-full bg-brand-yellow text-brand-ink font-semibold px-10 py-5 text-lg"
      >
        {t("hero.cta")}
      </a>
    </div>
  </div>
</section>